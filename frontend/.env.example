# Spring Boot API. No trailing slash.
# Geliştirmede boş bırakın: istekler Vite proxy ile http://localhost:8080'a gider (CORS sorunu olmaz).
# VITE_API_BASE_URL=
# Doğrudan backend adresi kullanmak için:
# VITE_API_BASE_URL=http://localhost:8080

# OAuth (Google / Facebook) istemci kimlikleri
# Google Cloud Console -> OAuth 2.0 Client ID (Web)
# VITE_GOOGLE_CLIENT_ID=your-google-client-id.apps.googleusercontent.com
# Facebook Developers -> App ID
# VITE_FACEBOOK_APP_ID=your-facebook-app-id
